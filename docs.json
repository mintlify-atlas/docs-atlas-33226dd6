{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Univerto",
  "theme": "mint",
  "colors": {
    "primary": "#848c8e",
    "light": "#11161e",
    "dark": "#cfd0d2"
  },
  "logo": {
    "light": "https://media.brand.dev/5ffd6ce4-2434-4b4b-920a-f8cacac8b48b.svg",
    "dark": "https://media.brand.dev/5ffd6ce4-2434-4b4b-920a-f8cacac8b48b.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/edumudu/univerto"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/edumudu/univerto"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/fluent-api", "concepts/precision", "concepts/high-precision-arithmetic"]
          },
          {
            "group": "Unit Converters",
            "pages": [
              "converters/length",
              "converters/area",
              "converters/volume",
              "converters/mass",
              "converters/time",
              "converters/speed",
              "converters/data",
              "converters/voltage",
              "converters/current",
              "converters/frequency"
            ]
          },
          {
            "group": "Advanced",
            "pages": ["advanced/tree-shaking", "advanced/typescript"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api/unit-converter",
              "api/conversion-methods",
              "api/types"
            ]
          }
        ]
      }
    ]
  }
}
